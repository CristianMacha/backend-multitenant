# ----- App -----
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ----- Database (PostgreSQL + Prisma) -----
DATABASE_URL=postgresql://bear:bear_secret@localhost:5432/bear_core?schema=public
POSTGRES_DB=bear_core
POSTGRES_USER=bear
POSTGRES_PASSWORD=bear_secret
POSTGRES_PORT=5432

# ----- Redis -----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ----- Firebase Admin SDK -----
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep the literal \n escapes inside the quotes
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ----- JWT validation metadata -----
JWT_AUDIENCE=
JWT_ISSUER=

# ----- API -----
SWAGGER_ENABLED=true
CORS_ORIGIN=http://localhost:5173,http://localhost:4200

# ----- Rate limiting (@nestjs/throttler) -----
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100
