generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  slug      String    @unique
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  users         User[]
  roles         Role[]
  auditLogs     AuditLog[]
  accounts      Account[]
  contacts      Contact[]
  pipelines     Pipeline[]
  opportunities Opportunity[]
  activities    Activity[]
  crmSettings   CrmSettings?
  notifications Notification[]
  products      Product[]

  @@map("tenants")
}

model User {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  firebaseUid String    @unique @map("firebase_uid")
  email       String
  firstName   String    @map("first_name")
  lastName    String    @map("last_name")
  isActive    Boolean   @default(true) @map("is_active")
  isPlatformAdmin Boolean @default(false) @map("is_platform_admin")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  userRoles     UserRole[]
  auditLogs     AuditLog[]
  notifications Notification[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model Role {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  name        String
  description String?
  isSystem    Boolean   @default(false) @map("is_system")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id          String    @id @default(uuid()) @db.Uuid
  code        String    @unique
  description String?
  module      String
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// --- CRM bounded context (crm) ---

enum AccountStatus {
  ACTIVE
  ARCHIVED

  @@map("account_status")
}

model Account {
  id        String        @id @default(uuid()) @db.Uuid
  tenantId  String        @map("tenant_id") @db.Uuid
  name      String
  industry  String?
  website   String?
  phone     String?
  address   Json?
  ownerId   String        @map("owner_id") @db.Uuid
  status    AccountStatus @default(ACTIVE)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  deletedAt DateTime?     @map("deleted_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  contacts Contact[]

  @@index([tenantId])
  @@index([tenantId, ownerId])
  @@map("accounts")
}

model Contact {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  firstName String    @map("first_name")
  lastName  String    @map("last_name")
  email     String?
  phone     String?
  jobTitle  String?   @map("job_title")
  accountId String?   @map("account_id") @db.Uuid
  ownerId   String    @map("owner_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  account Account? @relation(fields: [accountId], references: [id])

  @@index([tenantId])
  @@index([tenantId, ownerId])
  @@index([tenantId, accountId])
  @@map("contacts")
}

// --- Sales bounded context (sales) ---

enum StageType {
  OPEN
  WON
  LOST

  @@map("stage_type")
}

enum OpportunityStatus {
  OPEN
  WON
  LOST

  @@map("opportunity_status")
}

model Pipeline {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  name      String
  isDefault Boolean   @default(false) @map("is_default")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  stages        Stage[]
  opportunities Opportunity[]

  @@index([tenantId])
  @@map("pipelines")
}

// Stage is an aggregate-internal entity of Pipeline (like user_roles for User):
// it is synced within the Pipeline save transaction and hard-removed when the
// pipeline drops it, so it carries no soft-delete column.
model Stage {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  pipelineId  String    @map("pipeline_id") @db.Uuid
  name        String
  order       Int
  probability Int
  type        StageType
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  pipeline      Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  opportunities Opportunity[]

  @@index([tenantId])
  @@index([pipelineId])
  @@map("stages")
}

model Opportunity {
  id                String            @id @default(uuid()) @db.Uuid
  tenantId          String            @map("tenant_id") @db.Uuid
  name              String
  accountId         String            @map("account_id") @db.Uuid
  contactId         String?           @map("contact_id") @db.Uuid
  pipelineId        String            @map("pipeline_id") @db.Uuid
  stageId           String            @map("stage_id") @db.Uuid
  amount            Decimal           @default(0) @db.Decimal(14, 2)
  currency          String            @db.VarChar(3)
  expectedCloseDate DateTime?         @map("expected_close_date")
  ownerId           String            @map("owner_id") @db.Uuid
  status            OpportunityStatus @default(OPEN)
  closedAt          DateTime?         @map("closed_at")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  deletedAt         DateTime?         @map("deleted_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  pipeline Pipeline @relation(fields: [pipelineId], references: [id])
  stage    Stage    @relation(fields: [stageId], references: [id])

  @@index([tenantId])
  @@index([tenantId, pipelineId, stageId])
  @@index([tenantId, ownerId])
  @@index([tenantId, status])
  @@index([tenantId, contactId])
  @@map("opportunities")
}

// --- CRM activities (crm context, Phase 3) ---

enum ActivityType {
  CALL
  MEETING
  EMAIL
  TASK
  NOTE
  SYSTEM

  @@map("activity_type")
}

enum ActivityStatus {
  OPEN
  DONE

  @@map("activity_status")
}

enum ActivitySource {
  USER
  SYSTEM

  @@map("activity_source")
}

enum RelatedToType {
  ACCOUNT
  CONTACT
  OPPORTUNITY

  @@map("related_to_type")
}

model Activity {
  id            String         @id @default(uuid()) @db.Uuid
  tenantId      String         @map("tenant_id") @db.Uuid
  type          ActivityType
  subject       String
  body          String?
  dueAt         DateTime?      @map("due_at")
  completedAt   DateTime?      @map("completed_at")
  status        ActivityStatus @default(OPEN)
  ownerId       String?        @map("owner_id") @db.Uuid
  source        ActivitySource @default(USER)
  relatedToType RelatedToType  @map("related_to_type")
  relatedToId   String         @map("related_to_id") @db.Uuid
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  deletedAt     DateTime?      @map("deleted_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, ownerId])
  @@index([tenantId, relatedToType, relatedToId])
  @@index([tenantId, status, dueAt])
  @@map("activities")
}

model CrmSettings {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @unique @map("tenant_id") @db.Uuid
  defaultCurrency String    @default("USD") @map("default_currency")
  timezone        String    @default("UTC")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("crm_settings")
}

// --- Platform notifications ---

enum NotificationType {
  ACTIVITY_REMINDER
  SYSTEM
  GENERIC

  @@map("notification_type")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  tenantId  String           @map("tenant_id") @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType @default(GENERIC)
  title     String
  body      String
  read      Boolean          @default(false)
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  deletedAt DateTime?        @map("deleted_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([tenantId, userId, read])
  @@index([tenantId, userId, createdAt])
  @@map("notifications")
}

// --- Catalog bounded context ---

enum ProductType {
  PRODUCT
  SERVICE

  @@map("product_type")
}

enum ProductStatus {
  ACTIVE
  ARCHIVED

  @@map("product_status")
}

model Product {
  id            String        @id @default(uuid()) @db.Uuid
  tenantId      String        @map("tenant_id") @db.Uuid
  name          String
  description   String?
  type          ProductType
  category      String?
  unitPrice     Decimal       @default(0) @map("unit_price") @db.Decimal(14, 2)
  currency      String        @db.VarChar(3)
  unitOfMeasure String        @map("unit_of_measure")
  status        ProductStatus @default(ACTIVE)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  deletedAt     DateTime?     @map("deleted_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, status])
  @@index([tenantId, category])
  @@map("products")
}

model DomainEventOutbox {
  id          String    @id @default(uuid()) @db.Uuid
  aggregateId String    @map("aggregate_id")
  tenantId    String?   @map("tenant_id") @db.Uuid
  eventId     String    @unique @map("event_id")
  eventName   String    @map("event_name")
  payload     Json

  // Actor / request metadata captured at write time (inside the request),
  // so the background outbox processor can attribute the audit entry even
  // though it runs outside the request's AsyncLocalStorage context.
  userId        String? @map("user_id") @db.Uuid
  correlationId String? @map("correlation_id")
  ipAddress     String? @map("ip_address")
  userAgent     String? @map("user_agent")

  // Failure tracking so a poison message stops being retried forever and
  // does not starve newer events at the head of the queue. Rows with a
  // non-null failedAt are dead-lettered: excluded from the drain, kept for
  // inspection and manual replay (clear failedAt/attempts to requeue).
  attempts  Int       @default(0) @map("attempts")
  lastError String?   @map("last_error")
  failedAt  DateTime? @map("failed_at")

  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([publishedAt, createdAt])
  @@map("domain_event_outbox")
}

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String?  @map("tenant_id") @db.Uuid
  userId        String?  @map("user_id") @db.Uuid
  action        String
  entity        String
  entityId      String?  @map("entity_id")
  oldValues     Json?    @map("old_values")
  newValues     Json?    @map("new_values")
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  correlationId String?  @map("correlation_id")
  createdAt     DateTime @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  user   User?   @relation(fields: [userId], references: [id])

  @@index([tenantId, entity, entityId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}
